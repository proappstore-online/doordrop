import React, { useEffect, useMemo, useRef } from "react";
import { Map, AdvancedMarker, useMap, useMapsLibrary } from "@vis.gl/react-google-maps";
import { MarkerClusterer } from "@googlemaps/markerclusterer";
import { DoorData } from "../../models/door";
import { TrackPoint, TrackStop } from "../../models/campaign";
import type { OverpassAddress } from "../../utils/overpassQuery";

/**
 * Spread markers that share the same lat/lng into a small circle
 * so they don't stack on top of each other.
 */
function spreadOverlapping(
  items: { lat: number; lng: number }[]
): { lat: number; lng: number }[] {
  const groups: Record<string, number[]> = {};
  items.forEach((item, i) => {
    const key = `${item.lat},${item.lng}`;
    if (!groups[key]) groups[key] = [];
    groups[key].push(i);
  });

  const result = items.map((item) => ({ lat: item.lat, lng: item.lng }));
  for (const indices of Object.values(groups)) {
    if (indices.length <= 1) continue;
    const radius = 0.0002; // ~20m
    indices.forEach((idx: number, j: number) => {
      const angle = (2 * Math.PI * j) / indices.length;
      result[idx] = {
        lat: items[idx].lat + radius * Math.cos(angle),
        lng: items[idx].lng + radius * Math.sin(angle),
      };
    });
  }
  return result;
}

function dotColorForDoor(door: DoorData): { bg: string; border: string } {
  if (door.status === "delivered") return { bg: "#10b981", border: "#059669" };
  if (door.status === "reported") return { bg: "#f59e0b", border: "#d97706" };
  return { bg: "#ef4444", border: "#dc2626" };
}

// Walker position marker (larger, more visible)
function WalkerMarker() {
  return (
    <div style={{ position: 'relative' }}>
      {/* Pulsing outer ring */}
      <div
        style={{
          position: 'absolute',
          top: '-6px',
          left: '-6px',
          width: '24px',
          height: '24px',
          borderRadius: '50%',
          backgroundColor: '#3b82f6',
          opacity: 0.3,
          animation: 'pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite',
        }}
      />
      {/* Inner dot */}
      <div
        style={{
          width: '12px',
          height: '12px',
          borderRadius: '50%',
          backgroundColor: '#2563eb',
          border: '3px solid white',
          boxShadow: '0 2px 4px rgba(0,0,0,0.3)',
        }}
      />
    </div>
  );
}

type CampaignMapProps = {
  center: { lat: number; lng: number };
  zoom?: number;
  doors: (DoorData & { id?: string })[];
  /** Addresses from Overpass that are not yet selected */
  availableAddresses?: OverpassAddress[];
  /** House numbers currently selected (used to style markers) */
  selectedDoorKeys?: Set<string>;
  /** Called when an Overpass marker is clicked */
  onMarkerClick?: (address: OverpassAddress) => void;
  /** Called when a door marker is clicked */
  onDoorClick?: (door: DoorData & { id?: string }) => void;
  /** Walker's live GPS position — renders a blue dot */
  walkerPosition?: { lat: number; lng: number } | null;
  /** GPS track points to render as a polyline */
  trackPoints?: TrackPoint[];
  /** Detected stops to render as orange markers */
  trackStops?: TrackStop[];
  /** Per-door geofence radius in meters — renders circles */
  doorRadiusM?: number;
  /** Whether tracking is active (enables auto-follow) */
  isTracking?: boolean;
  className?: string;
};

/** Must be rendered inside an <APIProvider>. */
const CampaignMap: React.FC<CampaignMapProps> = ({
  center,
  zoom = 15,
  doors,
  availableAddresses = [],
  selectedDoorKeys,
  onMarkerClick,
  onDoorClick,
  walkerPosition,
  trackPoints,
  trackStops,
  doorRadiusM,
  isTracking = false,
  className,
}) => {
  const map = useMap("campaign-map");
  const markerLib = useMapsLibrary("marker");
  const polylineRef = useRef<google.maps.Polyline | null>(null);
  const circlesRef = useRef<google.maps.Circle[]>([]);
  const clustererRef = useRef<MarkerClusterer | null>(null);
  const doorMarkersRef = useRef<google.maps.marker.AdvancedMarkerElement[]>([]);

  const doorsWithCoords = useMemo(
    () => doors.filter((d) => d.lat && d.lng),
    [doors]
  );

  const spreadPositions = useMemo(
    () => spreadOverlapping(doorsWithCoords.map((d) => ({ lat: d.lat!, lng: d.lng! }))),
    [doorsWithCoords]
  );

  // Stable click handler ref to avoid recreating markers when callback changes
  const onDoorClickRef = useRef(onDoorClick);
  onDoorClickRef.current = onDoorClick;

  // Imperative door markers + clustering
  useEffect(() => {
    if (!map || !markerLib) return;

    // Clean up previous markers
    doorMarkersRef.current.forEach((m) => (m.map = null));
    doorMarkersRef.current = [];
    if (clustererRef.current) {
      clustererRef.current.clearMarkers();
      clustererRef.current = null;
    }

    const markers = doorsWithCoords.map((door, i) => {
      const colors = dotColorForDoor(door);
      const pos = spreadPositions[i];

      const dot = document.createElement("div");
      dot.style.width = "12px";
      dot.style.height = "12px";
      dot.style.borderRadius = "50%";
      dot.style.backgroundColor = colors.bg;
      dot.style.border = `2px solid ${colors.border}`;
      dot.style.cursor = "pointer";

      const marker = new markerLib.AdvancedMarkerElement({
        position: pos,
        title: door.address,
        content: dot,
        map, // will be managed by clusterer, but need initial map for creation
      });

      marker.addListener("click", () => {
        onDoorClickRef.current?.(door);
      });

      return marker;
    });

    doorMarkersRef.current = markers;

    // Create clusterer with custom renderer
    clustererRef.current = new MarkerClusterer({
      map,
      markers,
      renderer: {
        render({ count, position }) {
          const size = Math.min(24 + Math.log2(count) * 8, 56);
          const el = document.createElement("div");
          el.style.width = `${size}px`;
          el.style.height = `${size}px`;
          el.style.borderRadius = "50%";
          el.style.backgroundColor = "#10b981";
          el.style.border = "3px solid #059669";
          el.style.display = "flex";
          el.style.alignItems = "center";
          el.style.justifyContent = "center";
          el.style.color = "white";
          el.style.fontWeight = "bold";
          el.style.fontSize = "13px";
          el.style.boxShadow = "0 2px 6px rgba(0,0,0,0.3)";
          el.textContent = String(count);

          return new markerLib.AdvancedMarkerElement({
            position,
            content: el,
          });
        },
      },
    });

    return () => {
      doorMarkersRef.current.forEach((m) => (m.map = null));
      doorMarkersRef.current = [];
      if (clustererRef.current) {
        clustererRef.current.clearMarkers();
        clustererRef.current = null;
      }
    };
  }, [map, markerLib, doorsWithCoords, spreadPositions]);

  // Render track polyline
  useEffect(() => {
    if (!map) return;
    if (polylineRef.current) {
      polylineRef.current.setMap(null);
      polylineRef.current = null;
    }
    if (trackPoints && trackPoints.length >= 2) {
      polylineRef.current = new google.maps.Polyline({
        path: trackPoints.map((p) => ({ lat: p.lat, lng: p.lng })),
        strokeColor: "#3b82f6",
        strokeWeight: 3,
        strokeOpacity: 0.7,
        map,
      });
    }
    return () => {
      if (polylineRef.current) {
        polylineRef.current.setMap(null);
        polylineRef.current = null;
      }
    };
  }, [map, trackPoints]);

  // Render per-door geofence circles — skip when > 100 doors
  useEffect(() => {
    // Clean up previous circles
    circlesRef.current.forEach((c) => c.setMap(null));
    circlesRef.current = [];
    if (!map || !doorRadiusM || doorRadiusM <= 0) return;
    if (doorsWithCoords.length > 100) return;

    const circles = doorsWithCoords.map((d) =>
      new google.maps.Circle({
        center: { lat: d.lat!, lng: d.lng! },
        radius: doorRadiusM,
        fillColor: "#3b82f6",
        fillOpacity: 0.08,
        strokeColor: "#3b82f6",
        strokeOpacity: 0.3,
        strokeWeight: 1,
        map,
      })
    );
    circlesRef.current = circles;

    return () => {
      circles.forEach((c) => c.setMap(null));
      circlesRef.current = [];
    };
  }, [map, doorsWithCoords, doorRadiusM]);

  // Track whether user has manually changed zoom (pinch/scroll)
  const userOverrodeZoomRef = useRef(false);
  const programmaticZoomRef = useRef(false);

  useEffect(() => {
    if (!map) return;
    const listener = map.addListener("zoom_changed", () => {
      if (programmaticZoomRef.current) return;
      userOverrodeZoomRef.current = true;
    });
    return () => google.maps.event.removeListener(listener);
  }, [map]);

  // Auto-center on walker position during tracking
  const prevWalkerPosRef = useRef<{ lat: number; lng: number } | null>(null);
  const zoomSetRef = useRef(false);

  useEffect(() => {
    if (!map || !isTracking || !walkerPosition) {
      zoomSetRef.current = false;
      return;
    }

    // Set zoom once when tracking starts (user can override after)
    if (!zoomSetRef.current) {
      programmaticZoomRef.current = true;
      map.setZoom(23);
      programmaticZoomRef.current = false;
      zoomSetRef.current = true;
      userOverrodeZoomRef.current = false;
    }

    // Only pan if position changed significantly (> 5 meters)
    const prev = prevWalkerPosRef.current;
    if (prev) {
      const latDiff = Math.abs(walkerPosition.lat - prev.lat);
      const lngDiff = Math.abs(walkerPosition.lng - prev.lng);
      const threshold = 0.00005; // ~5 meters

      if (latDiff < threshold && lngDiff < threshold) {
        return;
      }
    }

    map.panTo(walkerPosition);
    prevWalkerPosRef.current = walkerPosition;
  }, [map, isTracking, walkerPosition]);

  // Fit bounds when doors/addresses count changes (not on every status update)
  // Skip if user has manually adjusted zoom
  const prevPointCountRef = useRef(0);
  useEffect(() => {
    if (!map || isTracking) return;
    const withCoords = doors.filter((d) => d.lat && d.lng);
    const allPoints = [
      ...withCoords.map((d) => ({ lat: d.lat!, lng: d.lng! })),
      ...availableAddresses.map((a) => ({ lat: a.lat, lng: a.lng })),
    ];
    // Only refit when the number of points changes (doors added/removed)
    if (allPoints.length === prevPointCountRef.current) return;
    prevPointCountRef.current = allPoints.length;
    if (userOverrodeZoomRef.current) return;
    if (allPoints.length === 0) {
      programmaticZoomRef.current = true;
      map.setCenter(center);
      map.setZoom(zoom);
      programmaticZoomRef.current = false;
      return;
    }
    const bounds = new google.maps.LatLngBounds();
    allPoints.forEach((p) => bounds.extend(p));
    programmaticZoomRef.current = true;
    map.fitBounds(bounds, 50);
    // fitBounds triggers zoom_changed async, reset flag after a tick
    setTimeout(() => { programmaticZoomRef.current = false; }, 100);
  }, [map, isTracking, doors, availableAddresses, center, zoom]);

  return (
    <div className={className ?? "w-full h-[400px] rounded-lg overflow-hidden border border-gray-300 dark:border-gray-600"}>
      <Map
        defaultCenter={center}
        defaultZoom={zoom}
        mapId="campaign-map"
        id="campaign-map"
        gestureHandling="greedy"
        mapTypeId="hybrid"
      >
        {/* Available addresses from Overpass */}
        {availableAddresses.map((addr) => {
          const isSelected = selectedDoorKeys?.has(addr.houseNumber);
          return (
            <AdvancedMarker
              key={`avail-${addr.houseNumber}`}
              position={{ lat: addr.lat, lng: addr.lng }}
              title={`${addr.houseNumber} ${addr.street}${addr.commercial ? " (Commercial)" : ""}`}
              onClick={() => onMarkerClick?.(addr)}
            >
              <div
                style={{
                  width: '12px',
                  height: '12px',
                  borderRadius: '50%',
                  backgroundColor: isSelected ? "#10b981" : "#9ca3af",
                  border: `2px solid ${isSelected ? "#059669" : "#6b7280"}`,
                  cursor: 'pointer',
                }}
              />
            </AdvancedMarker>
          );
        })}

        {/* Door markers are rendered imperatively via MarkerClusterer above */}

        {/* Walker live position (larger and more visible) */}
        {walkerPosition && (
          <AdvancedMarker position={walkerPosition} title="Your location" zIndex={1000}>
            <WalkerMarker />
          </AdvancedMarker>
        )}

        {/* Track stop markers */}
        {trackStops?.map((stop, i) => {
          const dwellSec = stop.endTime - stop.startTime;
          const dwellLabel = dwellSec >= 60 ? `${Math.floor(dwellSec / 60)}m ${dwellSec % 60}s` : `${dwellSec}s`;
          return (
            <AdvancedMarker
              key={`stop-${i}`}
              position={{ lat: stop.lat, lng: stop.lng }}
              title={`Stop: ${dwellLabel}`}
            >
              <div
                style={{
                  width: 12,
                  height: 12,
                  borderRadius: "50%",
                  background: "#f97316",
                  border: "2px solid #fff",
                  boxShadow: "0 0 4px rgba(249,115,22,0.5)",
                }}
              />
            </AdvancedMarker>
          );
        })}
      </Map>
    </div>
  );
};

export default React.memo(CampaignMap);
